page {
  background: #1a1a2e;
  color: #f0e6d3;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  min-height: 100vh;
}

/* 通用容器 */
.container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #e6b85c, #d4a056);
  color: #1a1a2e;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #f0e6d3;
  border-radius: 40rpx;
  padding: 24rpx 40rpx;
  font-size: 28rpx;
}

/* 通用标签样式 */
.tag {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #f0e6d3;
}

.tag-active {
  background: rgba(230, 184, 92, 0.3);
  border-color: #e6b85c;
  color: #e6b85c;
}

/* 通用输入框样式 */
.input {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  color: #f0e6d3;
  font-size: 28rpx;
}

/* 通用卡片样式 */
.card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 40rpx;
  padding: 40rpx;
}

/* 通用高亮文字 */
.text-primary {
  color: #e6b85c;
}

.text-secondary {
  color: #6b8cce;
}

.text-muted {
  color: #8b8b8b;
}