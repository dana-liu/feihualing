.container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.back {
  font-size: 32rpx;
  color: var(--text-primary);
}

.count {
  font-size: 28rpx;
  color: var(--text-muted);
}

.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}

.search-input::placeholder {
  color: var(--text-muted);
}

.filter-bar {
  margin-bottom: 20rpx;
}

.filter-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.filter-label {
  font-size: 26rpx;
  color: var(--text-muted);
}

.filter-options {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.filter-option {
  padding: 8rpx 20rpx;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.filter-option.selected {
  background: rgba(107, 140, 206, 0.3);
  border-color: #6b8cce;
  color: #6b8cce;
}

.poem-list {
  overflow: hidden;
}

.poem-item {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.poem-item:last-child {
  margin-bottom: 0;
}

.poem-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.poem-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.poem-author {
  font-size: 24rpx;
  color: var(--accent-secondary);
}

.poem-preview {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
  font-family: 'STKaiti', '楷体', serif;
}