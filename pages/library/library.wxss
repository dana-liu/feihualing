/* ============================================
   飞花令 - 诗词库页面 - 水墨丹青风格
   ============================================ */

page,
.container {
  min-height: 100vh;
  position: relative;
}

.container {
  padding: 0;
}

/* ==================== 背景装饰 ==================== */
.ink-wash-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  background:
    radial-gradient(ellipse 80% 40% at 20% 0%, var(--ink-wash, rgba(212, 165, 116, 0.04)) 0%, transparent 50%);
  z-index: 0;
}

.theme-dark .ink-wash-bg {
  --ink-wash: rgba(212, 165, 116, 0.06);
}

/* ==================== 头部 ==================== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  position: relative;
  z-index: 1;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.back-btn:active {
  transform: scale(0.95);
}

.back-icon {
  font-size: 32rpx;
  color: var(--text-primary);
}

.back-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-family: 'STKaiti', '楷体', serif;
}

.count-badge {
  padding: 12rpx 24rpx;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-family: 'STKaiti', '楷体', serif;
}

/* ==================== 搜索区域 ==================== */
.search-section {
  padding: 0 40rpx 30rpx;
  position: relative;
  z-index: 1;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.search-icon {
  font-size: 32rpx;
  color: var(--text-muted);
}

.search-input {
  flex: 1;
  background: transparent;
  border: none;
  color: var(--text-primary);
  font-size: 28rpx;
  font-family: 'STKaiti', '楷体', serif;
}

.search-placeholder {
  color: var(--text-muted);
}

/* ==================== 筛选区域 ==================== */
.filter-section {
  padding: 0 40rpx 30rpx;
  position: relative;
  z-index: 1;
}

.filter-scroll {
  display: flex;
  align-items: center;
  gap: 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-scroll::-webkit-scrollbar {
  display: none;
}

.filter-label {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: 'STKaiti', '楷体', serif;
  white-space: nowrap;
}

.filter-options {
  display: flex;
  gap: 12rpx;
  flex-wrap: nowrap;
}

.filter-option {
  padding: 10rpx 24rpx;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  transition: all 0.3s ease;
}

.filter-option.selected {
  background: linear-gradient(135deg, var(--accent-gold), var(--accent-cinnabar));
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx var(--shadow-color);
}

/* ==================== 诗词列表 ==================== */
.poem-scroll {
  position: relative;
  z-index: 1;
  height: calc(100vh - 350rpx);
}

.poem-list {
  padding: 0 40rpx 40rpx;
}

.poem-item {
  position: relative;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
}

.poem-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx var(--shadow-color);
}

.item-decoration {
  position: absolute;
  left: 0;
  right: 0;
  height: 4rpx;
}

.item-decoration.top {
  top: 0;
  background: linear-gradient(90deg, var(--accent-gold), var(--accent-cinnabar), transparent);
}

.item-decoration.bottom {
  bottom: 0;
  background: linear-gradient(90deg, transparent, var(--accent-jade));
}

.item-content {
  padding: 0 50rpx 0 0;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.poem-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-family: 'STKaiti', '楷体', serif;
  font-weight: bold;
}

.dynasty-tag {
  padding: 4rpx 12rpx;
  background: var(--accent-gold);
  color: #fff;
  font-size: 18rpx;
  border-radius: 20rpx;
}

.poem-author {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
}

.poem-preview {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-family: 'STKaiti', '楷体', serif;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-arrow {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: var(--text-muted);
  font-weight: 300;
}

/* ==================== 空状态 ==================== */
.empty-state {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: var(--text-muted);
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  font-family: 'STKaiti', '楷体', serif;
}

/* ==================== 加载更多 ==================== */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: 'STKaiti', '楷体', serif;
}

.no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.no-more-text {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: 'STKaiti', '楷体', serif;
  opacity: 0.6;
}