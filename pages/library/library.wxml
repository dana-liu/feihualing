<view class="container {{isDarkMode ? 'theme-dark' : 'theme-warm'}}">
  <view class="header">
    <text class="back" bindtap="goBack">← 返回</text>
    <text class="count">共 {{filteredPoems.length}} 首</text>
  </view>

  <view class="search-bar">
    <input class="search-input" placeholder="搜索诗词、作者..." bindinput="onSearch" value="{{searchText}}"/>
  </view>

  <view class="filter-bar">
    <view class="filter-group">
      <text class="filter-label">朝代：</text>
      <view class="filter-options">
        <view
          wx:for="{{dynastyOptions}}"
          wx:key="index"
          class="filter-option {{selectedDynasty === item ? 'selected' : ''}}"
          bindtap="selectDynasty"
          data-dynasty="{{item}}"
        >{{item}}</view>
      </view>
    </view>
  </view>

  <view class="poem-list">
    <view class="poem-item" wx:for="{{filteredPoems}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="poem-header">
        <text class="poem-title">《{{item.title}}》</text>
        <text class="poem-author">{{item.dynasty}} · {{item.author}}</text>
      </view>
      <text class="poem-preview">{{item.content}}</text>
    </view>
  </view>
</view>