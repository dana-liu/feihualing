<view class="container {{isDarkMode ? 'theme-dark' : 'theme-warm'}}">
  <!-- 背景装饰 -->
  <view class="ink-wash-bg"></view>

  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
      <text class="back-text">返回</text>
    </view>
    <view class="count-badge">共 {{filteredPoems.length}} 首</view>
  </view>

  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索诗词、作者..."
        bindinput="onSearch"
        value="{{searchText}}"
        placeholder-class="search-placeholder"
      />
    </view>
  </view>

  <view class="filter-section">
    <view class="filter-scroll">
      <text class="filter-label">朝代</text>
      <view class="filter-options">
        <view
          wx:for="{{dynastyOptions}}"
          wx:key="index"
          class="filter-option {{selectedDynasty === item ? 'selected' : ''}}"
          bindtap="selectDynasty"
          data-dynasty="{{item}}"
        >{{item}}</view>
      </view>
    </view>
  </view>

  <scroll-view
    class="poem-scroll"
    scroll-y
    bindscrolltolower="onScrollToLower"
    lower-threshold="100"
  >
    <view class="poem-list">
      <view
        class="poem-item"
        wx:for="{{displayPoems}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="item-decoration top"></view>
        <view class="item-content">
          <view class="item-header">
            <text class="poem-title">《{{item.title}}》</text>
            <view class="dynasty-tag">{{item.dynasty}}</view>
          </view>
          <text class="poem-author">{{item.author}}</text>
          <text class="poem-preview">{{item.content}}</text>
        </view>
        <view class="item-arrow">›</view>
        <view class="item-decoration bottom"></view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}">
      <text class="loading-text">上滑加载更多</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && displayPoems.length > 0}}">
      <text class="no-more-text">— 已加载全部 —</text>
    </view>
  </scroll-view>

  <view class="empty-state" wx:if="{{filteredPoems.length === 0}}">
    <text class="empty-icon">☯</text>
    <text class="empty-text">暂无相关诗词</text>
  </view>
</view>