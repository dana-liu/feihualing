.container {
  min-height: 100vh;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  display: block;
  font-size: 72rpx;
  color: #f0e6d3;
  font-family: 'STKaiti', '楷体', serif;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #8b8b8b;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.mode-card {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.mode-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 48rpx;
}

.mode-title {
  display: block;
  font-size: 36rpx;
  color: #f0e6d3;
  margin-bottom: 8rpx;
}

.mode-desc {
  font-size: 26rpx;
  color: #8b8b8b;
}

.footer {
  text-align: center;
  margin-top: 120rpx;
}

.quote {
  font-size: 24rpx;
  color: #5a5a6e;
  font-family: 'STKaiti', '楷体', serif;
}