.container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back {
  font-size: 32rpx;
  color: #f0e6d3;
}

/* 诗词卡片 */
.poetry-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 50rpx;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.poetry-content {
  text-align: center;
  margin-bottom: 40rpx;
}

.poetry-sentence {
  display: block;
  line-height: 2;
  letter-spacing: 4rpx;
}

.keyword-char {
  color: #e6b85c;
  font-weight: bold;
}

.punctuation {
  color: #8b8b8b;
}

.poetry-info {
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 40rpx;
}

.poetry-title {
  display: block;
  font-size: 36rpx;
  color: #8b8b8b;
  margin-bottom: 8rpx;
}

.poetry-author {
  font-size: 30rpx;
  color: #6b8cce;
}

/* 关键字区域 */
.keyword-section {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 40rpx;
  padding: 40rpx;
}

.keyword-title {
  font-size: 28rpx;
  color: #8b8b8b;
  display: block;
  margin-bottom: 30rpx;
}

.keyword-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.keyword-tag {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #f0e6d3;
  font-family: 'STKaiti', '楷体', serif;
}
