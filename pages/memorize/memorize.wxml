<view class="container">
  <!-- 关键字输入界面 -->
  <view wx:if="{{!keyword}}" class="keyword-input-view">
    <view class="header">
      <text class="back" bindtap="goBack">← 返回</text>
    </view>
    <view class="input-title">请输入一个关键字</view>

    <view class="input-box">
      <input
        class="keyword-input"
        maxlength="1"
        bindinput="onKeywordInput"
        value="{{inputKeyword}}"
      />
      <button class="start-btn" bindtap="startMemorize" disabled="{{!inputKeyword}}">开始</button>
    </view>

    <view class="hint">选择一个关键字，系统将展示包含该字的诗词</view>

    <view class="suggested-keywords">
      <view class="suggested-title">热门关键字</view>
      <view class="keyword-tags">
        <view
          wx:for="{{suggestedKeywords}}"
          wx:key="index"
          class="keyword-tag"
          bindtap="selectSuggested"
          data-keyword="{{item}}"
        >{{item}}</view>
      </view>
    </view>

    <button class="random-btn" bindtap="randomKeyword">随机关键字</button>
  </view>

  <!-- 诗词浏览界面 -->
  <view wx:else class="poetry-view">
    <view class="header">
      <text class="back" bindtap="goBack">← 返回</text>
      <text class="progress">{{currentIndex + 1}}/{{totalCount}} 首</text>
    </view>

    <view class="keyword-show">
      <text class="keyword-label">当前关键字：</text>
      <text class="keyword-value">{{keyword}}</text>
    </view>

    <view class="poetry-card">
      <view class="card-header">
        <text class="poetry-title">《{{currentPoem.title}}》</text>
        <text class="favorite-btn {{isFavorited ? 'favorited' : ''}}" bindtap="toggleFavorite"> {{isFavorited ? '★' : '☆'}}</text>
      </view>

      <view class="poetry-content">
        <view wx:for="{{currentPoem.sentences}}" wx:key="index" class="poetry-sentence">
          <text wx:for="{{item}}" wx:for-item="char" wx:key="charIdx" class="{{char.isKeyword ? 'keyword-char' : ''}} {{char.isPunctuation ? 'punctuation' : ''}}">{{char.char}}</text>
        </view>
      </view>

      <view class="poetry-info">
        <text class="poetry-author">{{currentPoem.dynasty}} · {{currentPoem.author}}</text>
      </view>
    </view>

    <view class="action-btns">
      <button class="nav-btn prev" bindtap="prevPoem" disabled="{{currentIndex === 0}}">← 上一首</button>
      <button class="nav-btn next" bindtap="nextPoem" disabled="{{currentIndex >= totalCount - 1}}">下一首 →</button>
    </view>

    <view class="progress-bar">
      <text class="progress-title">{{currentPoem.title}}</text>
      <text class="progress-next">{{nextTitle}}</text>
      <view class="bar-track">
        <view class="bar-fill" style="width: {{progress}}%;"></view>
      </view>
    </view>

    <button class="change-btn" bindtap="changeKeyword">换个关键字</button>
  </view>
</view>
