.container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back {
  font-size: 32rpx;
  color: #f0e6d3;
}

.progress {
  font-size: 28rpx;
  color: #6b8cce;
}

/* 关键字输入界面 */
.keyword-input-view {
  padding-top: 60rpx;
}

.input-title {
  text-align: center;
  font-size: 36rpx;
  color: #f0e6d3;
  margin-bottom: 60rpx;
}

.input-box {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 48rpx;
  padding: 16rpx 24rpx;
}

.keyword-input {
  flex: 1;
  background: transparent;
  border: none;
  padding: 20rpx;
  color: #f0e6d3;
  font-size: 48rpx;
  text-align: center;
  font-family: 'STKaiti', '楷体', serif;
}

.keyword-input::placeholder {
  color: #5a5a6e;
  font-size: 32rpx;
}

.start-btn {
  background: linear-gradient(135deg, #e6b85c, #d4a056);
  color: #1a1a2e;
  border: none;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.start-btn[disabled] {
  background: rgba(255, 255, 255, 0.1);
  color: #5a5a6e;
}

.hint {
  text-align: center;
  font-size: 26rpx;
  color: #5a5a6e;
  margin-top: 30rpx;
}

.suggested-keywords {
  margin-top: 80rpx;
}

.suggested-title {
  text-align: center;
  font-size: 28rpx;
  color: #8b8b8b;
  margin-bottom: 30rpx;
}

.keyword-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.keyword-tag {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 32rpx;
  color: #f0e6d3;
  font-family: 'STKaiti', '楷体', serif;
}

/* 诗词卡片 */
.poetry-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 50rpx;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.poetry-content {
  text-align: center;
  margin-bottom: 40rpx;
}

.poetry-line {
  display: block;
  color: #f0e6d3;
  font-size: 48rpx;
  line-height: 1.8;
  font-family: 'STKaiti', '楷体', serif;
}

.poetry-info {
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 40rpx;
}

.poetry-title {
  display: block;
  font-size: 28rpx;
  color: #8b8b8b;
  margin-bottom: 8rpx;
}

.poetry-author {
  font-size: 26rpx;
  color: #6b8cce;
}

.action-btns {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 60rpx;
}

.nav-btn {
  flex: 1;
  padding: 32rpx;
  border-radius: 60rpx;
  font-size: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #f0e6d3;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.nav-btn.next {
  background: linear-gradient(135deg, #6b8cce, #5a7ab8);
  color: #fff;
  border: none;
}

.nav-btn[disabled] {
  opacity: 0.4;
}

.progress-bar {
  margin-top: 30rpx;
}

.progress-title {
  font-size: 24rpx;
  color: #5a5a6e;
}

.progress-next {
  font-size: 24rpx;
  color: #5a5a6e;
  float: right;
}

.bar-track {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  height: 8rpx;
  margin-top: 16rpx;
}

.bar-fill {
  background: #6b8cce;
  border-radius: 8rpx;
  height: 100%;
  transition: width 0.3s;
}

/* 关键字展示 */
.keyword-show {
  text-align: center;
  margin-bottom: 40rpx;
}

.keyword-label {
  font-size: 28rpx;
  color: #8b8b8b;
}

.keyword-value {
  font-size: 36rpx;
  color: #e6b85c;
  font-family: 'STKaiti', '楷体', serif;
  font-weight: bold;
}

/* 切换关键字按钮 */
.change-btn {
  display: block;
  width: 100%;
  margin-top: 40rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 60rpx;
  color: #8b8b8b;
  font-size: 28rpx;
  text-align: center;
}
