.container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back {
  font-size: 32rpx;
  color: #f0e6d3;
}

.progress {
  font-size: 28rpx;
  color: #6b8cce;
}

.poetry-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 50rpx;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.poetry-content {
  text-align: center;
  margin-bottom: 40rpx;
}

.poetry-line {
  display: block;
  color: #f0e6d3;
  font-size: 48rpx;
  line-height: 1.8;
  font-family: 'STKaiti', '楷体', serif;
}

.poetry-info {
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 40rpx;
}

.poetry-title {
  display: block;
  font-size: 28rpx;
  color: #8b8b8b;
  margin-bottom: 8rpx;
}

.poetry-author {
  font-size: 26rpx;
  color: #6b8cce;
}

.action-btns {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 60rpx;
}

.nav-btn {
  flex: 1;
  padding: 32rpx;
  border-radius: 60rpx;
  font-size: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #f0e6d3;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.nav-btn.next {
  background: linear-gradient(135deg, #6b8cce, #5a7ab8);
  color: #fff;
  border: none;
}

.nav-btn[disabled] {
  opacity: 0.4;
}

.progress-bar {
  margin-top: 30rpx;
}

.progress-title {
  font-size: 24rpx;
  color: #5a5a6e;
}

.progress-next {
  font-size: 24rpx;
  color: #5a5a6e;
  float: right;
}

.bar-track {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  height: 8rpx;
  margin-top: 16rpx;
}

.bar-fill {
  background: #6b8cce;
  border-radius: 8rpx;
  height: 100%;
  transition: width 0.3s;
}