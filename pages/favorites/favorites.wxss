.container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back {
  font-size: 32rpx;
  color: var(--text-primary);
}

.title {
  font-size: 36rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.count {
  font-size: 28rpx;
  color: var(--text-muted);
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: var(--text-muted);
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-muted);
  margin-top: 30rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 20rpx;
}

.poem-list {
  display: flex;
  flex-direction: column;
}

.poem-item {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.poem-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.poem-title {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
}

.poem-author {
  font-size: 24rpx;
  color: var(--accent-secondary);
}

.poem-preview {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
  font-family: 'STKaiti', '楷体', serif;
}