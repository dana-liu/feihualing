/* ============================================
   飞花令 - 我的收藏页面 - 水墨丹青风格
   ============================================ */

page,
.container {
  min-height: 100vh;
  position: relative;
}

.container {
  padding: 0;
}

/* ==================== 背景装饰 ==================== */
.ink-wash-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  background:
    radial-gradient(ellipse 60% 50% at 80% 20%, var(--ink-wash, rgba(212, 165, 116, 0.04)) 0%, transparent 50%),
    radial-gradient(ellipse 50% 40% at 20% 80%, var(--ink-wash-bottom, rgba(199, 62, 58, 0.03)) 0%, transparent 50%);
  z-index: 0;
}

.theme-dark .ink-wash-bg {
  --ink-wash: rgba(212, 165, 116, 0.06);
  --ink-wash-bottom: rgba(199, 62, 58, 0.05);
}

/* ==================== 头部 ==================== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  position: relative;
  z-index: 1;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 40rpx;
}

.back-btn:active {
  transform: scale(0.95);
}

.back-icon {
  font-size: 32rpx;
  color: var(--text-primary);
}

.back-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-family: 'STKaiti', '楷体', serif;
}

.title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-seal {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--accent-cinnabar);
  border: 2rpx solid var(--accent-cinnabar);
  border-radius: 8rpx;
  transform: rotate(-5deg);
}

.title-text {
  font-size: 34rpx;
  color: var(--text-primary);
  font-family: 'STKaiti', '楷体', serif;
  font-weight: bold;
}

.count-badge {
  padding: 12rpx 24rpx;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-family: 'STKaiti', '楷体', serif;
}

/* ==================== 空状态 ==================== */
.empty-tip {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon-wrapper {
  width: 140rpx;
  height: 140rpx;
  line-height: 140rpx;
  text-align: center;
  border: 2rpx dashed var(--card-border);
  border-radius: 50%;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.empty-icon {
  font-size: 60rpx;
  color: var(--text-muted);
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  font-family: 'STKaiti', '楷体', serif;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: 'STKaiti', '楷体', serif;
}

/* ==================== 诗词列表 ==================== */
.poem-list {
  position: relative;
  z-index: 1;
  padding: 0 40rpx 40rpx;
}

.poem-item {
  position: relative;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 24rpx;
  padding: 30rpx;
  padding-left: 40rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx var(--shadow-color);
}

.poem-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx var(--shadow-color);
}

.item-decoration {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 6rpx;
}

.item-decoration.left {
  left: 0;
  background: linear-gradient(180deg, var(--accent-gold), var(--accent-cinnabar));
}

.item-content {
  padding-right: 50rpx;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.poem-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-family: 'STKaiti', '楷体', serif;
  font-weight: bold;
}

.author-badge {
  padding: 4rpx 12rpx;
  background: var(--accent-jade);
  color: #fff;
  font-size: 18rpx;
  border-radius: 20rpx;
}

.poem-author {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
}

.poem-preview {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-family: 'STKaiti', '楷体', serif;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-arrow {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: var(--text-muted);
  font-weight: 300;
}