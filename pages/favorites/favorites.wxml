<view class="container {{isDarkMode ? 'theme-dark' : 'theme-warm'}}">
  <!-- 背景装饰 -->
  <view class="ink-wash-bg"></view>

  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
      <text class="back-text">返回</text>
    </view>
    <view class="title-wrapper">
      <view class="title-seal">藏</view>
      <text class="title-text">我的收藏</text>
    </view>
    <view class="count-badge">{{poems.length}} 首</view>
  </view>

  <view class="empty-tip" wx:if="{{poems.length === 0}}">
    <view class="empty-icon-wrapper">
      <text class="empty-icon">☆</text>
    </view>
    <text class="empty-text">暂无收藏诗词</text>
    <text class="empty-hint">在诗词详情页点击★收藏诗词</text>
  </view>

  <view class="poem-list" wx:else>
    <view
      class="poem-item"
      wx:for="{{poems}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="item-decoration left"></view>
      <view class="item-content">
        <view class="item-header">
          <text class="poem-title">《{{item.title}}》</text>
          <view class="author-badge">{{item.dynasty}}</view>
        </view>
        <text class="poem-author">{{item.author}}</text>
        <text class="poem-preview">{{item.content}}</text>
      </view>
      <view class="item-arrow">›</view>
    </view>
  </view>
</view>