<view class="container {{isDarkMode ? 'theme-dark' : 'theme-warm'}}">
  <view class="header">
    <text class="back" bindtap="goBack">← 返回</text>
    <text class="title">我的收藏</text>
    <text class="count">{{poems.length}} 首</text>
  </view>

  <view class="empty-tip" wx:if="{{poems.length === 0}}">
    <text class="empty-icon">☆</text>
    <text class="empty-text">暂无收藏诗词</text>
    <text class="empty-hint">在背诗模式中点击☆收藏诗词</text>
  </view>

  <view class="poem-list" wx:else>
    <view class="poem-item" wx:for="{{poems}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="poem-header">
        <text class="poem-title">《{{item.title}}》</text>
        <text class="poem-author">{{item.dynasty}} · {{item.author}}</text>
      </view>
      <text class="poem-preview">{{item.content}}</text>
    </view>
  </view>
</view>
