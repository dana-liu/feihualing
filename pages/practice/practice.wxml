<view class="container">
  <!-- 关键字输入界面 -->
  <view wx:if="{{!keyword}}" class="keyword-input-view">
    <view class="header">
      <text class="back" bindtap="goBack">← 返回</text>
    </view>
    <view class="input-title">请输入一个关键字</view>

    <view class="input-box">
      <input
        class="keyword-input"
        maxlength="1"
        bindinput="onKeywordInput"
        value="{{inputKeyword}}"
      />
      <button class="start-btn" bindtap="startPractice" disabled="{{!inputKeyword}}">开始</button>
    </view>

    <view class="hint">选择一个关键字，系统将展示包含该字的诗词</view>

    <view class="suggested-keywords">
      <view class="suggested-title">热门关键字</view>
      <view class="keyword-tags">
        <view
          wx:for="{{suggestedKeywords}}"
          wx:key="index"
          class="keyword-tag"
          bindtap="selectSuggested"
          data-keyword="{{item}}"
        >{{item}}</view>
      </view>
    </view>

    <button class="random-btn" bindtap="randomKeyword">随机关键字</button>
  </view>

  <!-- 练习界面 -->
  <view wx:else class="practice-view">
    <view class="header">
      <text class="back" bindtap="goBack">← 返回</text>
      <text class="progress">第 {{currentRound}}/{{totalRounds}} 轮</text>
    </view>

    <view class="keyword-show">
      <text class="keyword-label">当前关键字：</text>
      <text class="keyword-value">{{keyword}}</text>
    </view>

    <view class="progress-dots">
      <block wx:for="{{totalRounds}}" wx:key="index">
        <view class="dot {{index < currentRound ? 'active' : ''}}"></view>
      </block>
    </view>

    <view class="input-section">
      <view class="input-box">
        <input class="poetry-input" placeholder="请输入连续两句诗..." placeholder-class="input-placeholder" bindinput="onInput" value="{{inputText}}"/>
        <button class="voice-btn" bindtap="toggleVoice">
          <text class="voice-icon">🎤</text>
        </button>
      </view>
      <text class="input-hint">输入连续的两句诗（8-30字）</text>
    </view>

    <view class="result-section" wx:if="{{showResult}}">
      <view class="result-box {{isCorrect ? 'correct' : 'wrong'}}">
        <text class="result-icon">{{isCorrect ? '✓' : '✗'}}</text>
        <view class="result-info">
          <text class="result-title">{{isCorrect ? '回答正确！' : '回答错误'}}</text>
          <text class="result-poetry" wx:if="{{isCorrect}}">{{matchedPoetry}}</text>
        </view>
      </view>
    </view>

    <!-- 答对动效 -->
    <view wx:if="{{showSuccessAnimation}}" class="success-animation">
      <view class="success-content">
        <view class="success-icon">🎉</view>
        <view class="success-text">{{successMessage}}</view>
      </view>
    </view>

    <view class="action-section">
      <button class="submit-btn" bindtap="submitAnswer" disabled="{{!inputText}}">提交答案</button>
    </view>

    <button class="change-btn" bindtap="changeKeyword">换个关键字</button>
  </view>
</view>
