.container {
  padding: 30rpx 40rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back {
  font-size: 32rpx;
  color: #f0e6d3;
}

.progress {
  font-size: 28rpx;
  color: #e6b85c;
}

.keyword-section {
  text-align: center;
  margin-bottom: 50rpx;
}

.keyword-label {
  font-size: 28rpx;
  color: #8b8b8b;
  margin-bottom: 16rpx;
  display: block;
}

.keyword-box {
  display: inline-block;
  background: linear-gradient(135deg, #e6b85c, #d4a056);
  color: #1a1a2e;
  font-size: 120rpx;
  font-family: 'STKaiti', '楷体', serif;
  padding: 50rpx 120rpx;
  border-radius: 32rpx;
  font-weight: bold;
}

.progress-dots {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 50rpx;
}

.dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 2px solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.dot.completed {
  background: #7eb89b;
  border-color: #7eb89b;
  color: #fff;
}

.input-section {
  margin-bottom: 40rpx;
}

.input-box {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 48rpx;
  padding: 12rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.poetry-input {
  flex: 1;
  background: transparent;
  border: none;
  padding: 20rpx 32rpx;
  color: #f0e6d3;
  font-size: 30rpx;
}

.input-placeholder {
  color: #5a5a6e;
}

.voice-btn {
  width: 32rpx;
  height: 64rpx;
  background: #e6b85c;
  border: none;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  flex-shrink: 0;
  box-sizing: border-box;
}

.voice-icon {
  font-size: 32rpx;
}

.input-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #5a5a6e;
  margin-top: 20rpx;
}

.round-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
  gap: 20rpx;
}

.round-label {
  font-size: 28rpx;
  color: #8b8b8b;
}

.round-options {
  display: flex;
  gap: 16rpx;
}

.round-option {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #8b8b8b;
}

.round-option.selected {
  background: rgba(107, 140, 206, 0.3);
  border-color: #6b8cce;
  color: #6b8cce;
}

.result-section {
  margin-bottom: 40rpx;
}

.result-box {
  position: relative;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.result-box.correct {
  background: rgba(126, 184, 155, 0.2);
  border: 1px solid #7eb89b;
}

.result-box.wrong {
  background: rgba(206, 107, 107, 0.2);
  border: 1px solid #ce6b6b;
}

.result-icon {
  font-size: 40rpx;
}

.result-box.correct .result-icon {
  color: #7eb89b;
}

.result-box.wrong .result-icon {
  color: #ce6b6b;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #f0e6d3;
  display: block;
}

.result-poetry {
  font-size: 26rpx;
  color: #a0d4be;
  margin-top: 8rpx;
  display: block;
  font-family: 'STKaiti', '楷体', serif;
}

.result-hint {
  font-size: 26rpx;
  color: #8b8b8b;
  margin-top: 16rpx;
  display: block;
  font-family: 'STKaiti', '楷体', serif;
}

.hint-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(107, 140, 206, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #6b8cce;
}

.hint-tag.hide {
  display: none;
}

.action-section {
  text-align: center;
}

.submit-btn {
  background: linear-gradient(135deg, #e6b85c, #d4a056);
  color: #1a1a2e;
  border: none;
  padding: 28rpx 60rpx;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: bold;
  white-space: nowrap;
}

/* 关键字输入界面 */
.keyword-input-view {
  padding-top: 60rpx;
}

.input-title {
  text-align: center;
  font-size: 36rpx;
  color: #f0e6d3;
  margin-bottom: 60rpx;
}

.hint {
  text-align: center;
  font-size: 26rpx;
  color: #5a5a6e;
  margin-top: 30rpx;
}

.suggested-keywords {
  margin-top: 60rpx;
}

.suggested-title {
  text-align: center;
  font-size: 28rpx;
  color: #8b8b8b;
  margin-bottom: 30rpx;
}

.keyword-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.keyword-tag {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 32rpx;
  color: #f0e6d3;
  font-family: 'STKaiti', '楷体', serif;
}

.start-btn {
  background: linear-gradient(135deg, #e6b85c, #d4a056);
  color: #1a1a2e;
  border: none;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.start-btn[disabled] {
  background: rgba(255, 255, 255, 0.1);
  color: #5a5a6e;
}

.random-btn {
  display: block;
  width: 100%;
  margin-top: 60rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 60rpx;
  color: #8b8b8b;
  font-size: 28rpx;
  text-align: center;
}

/* 关键字展示 */
.keyword-show {
  text-align: center;
  margin-bottom: 40rpx;
}

.keyword-value {
  font-size: 56rpx;
  color: #e6b85c;
  font-family: 'STKaiti', '楷体', serif;
  font-weight: bold;
}

/* 切换关键字按钮 */
.change-btn {
  display: block;
  width: 100%;
  margin-top: 40rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 60rpx;
  color: #8b8b8b;
  font-size: 28rpx;
  text-align: center;
}

/* 答对动效 */
.success-animation {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease-out;
  z-index: 100;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.success-content {
  background: linear-gradient(135deg, #e6b85c, #d4a056);
  padding: 60rpx 80rpx;
  border-radius: 30rpx;
  text-align: center;
  animation: scaleIn 0.4s ease-out;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.success-icon {
  font-size: 100rpx;
  animation: bounce 0.6s ease-in-out infinite;
}

.success-text {
  font-size: 40rpx;
  color: #1a1a2e;
  font-weight: bold;
  margin-top: 20rpx;
  font-family: 'STKaiti', '楷体', serif;
}

/* 完成弹窗 */
.complete-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease-out;
  z-index: 100;
}

.modal-content {
  background: linear-gradient(135deg, #e6b85c, #d4a056);
  padding: 60rpx 50rpx;
  border-radius: 30rpx;
  text-align: center;
  animation: scaleIn 0.4s ease-out;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  width: 500rpx;
}

.modal-icon {
  font-size: 100rpx;
}

.modal-text {
  font-size: 36rpx;
  color: #1a1a2e;
  font-weight: bold;
  margin-top: 20rpx;
  font-family: 'STKaiti', '楷体', serif;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.continue-btn {
  background: #fff;
  color: #e6b85c;
  border: none;
}

.home-btn {
  background: rgba(255, 255, 255, 0.3);
  color: #1a1a2e;
  border: 2px solid #1a1a2e;
}