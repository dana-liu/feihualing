/* ============================================
   飞花令 - 个人练习页面 - 暖阁书香风格
   ============================================ */

page,
.container {
  min-height: 100vh;
  position: relative;
}

.container {
  padding: 0;
}

/* ==================== 背景 ==================== */
.ink-wash-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.theme-warm .ink-wash-bg {
  background:
    radial-gradient(ellipse 90% 60% at 50% 0%, rgba(199, 90, 60, 0.06) 0%, transparent 50%),
    radial-gradient(ellipse 80% 50% at 80% 100%, rgba(180, 140, 100, 0.08) 0%, transparent 40%);
}

.theme-dark .ink-wash-bg {
  background:
    radial-gradient(ellipse 90% 60% at 50% 0%, rgba(139, 70, 50, 0.08) 0%, transparent 50%),
    radial-gradient(ellipse 80% 50% at 20% 100%, rgba(100, 80, 60, 0.05) 0%, transparent 40%);
}

.paper-texture {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
}

/* ==================== 头部 ==================== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 50rpx 40rpx 30rpx;
  position: relative;
  z-index: 1;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.back-btn:active {
  transform: scale(0.92);
  opacity: 0.8;
}

.back-icon {
  font-size: 32rpx;
  color: var(--text-primary);
}

.page-title {
  font-size: 34rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-primary);
  font-weight: bold;
  letter-spacing: 4rpx;
}

.placeholder {
  width: 72rpx;
}

/* ==================== 输入界面 ==================== */
.keyword-input-view {
  position: relative;
  z-index: 1;
  min-height: 100vh;
}

.main-content {
  padding: 0 50rpx 60rpx;
}

/* 标题区 */
.title-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.title-flourish {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--accent-cinnabar), transparent);
}

.main-title {
  font-size: 44rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-primary);
  font-weight: bold;
  letter-spacing: 8rpx;
}

.section-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
  margin-bottom: 50rpx;
}

/* ==================== 关键字输入框 - 印章风格 ==================== */
.input-showcase {
  display: flex;
  justify-content: center;
  margin-bottom: 50rpx;
  position: relative;
}

.seal-box {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.seal-inner {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #FDF6E8 0%, #F5EBD5 50%, #EBD9B8 100%);
  border-radius: 8rpx;
  position: relative;
  box-shadow:
    inset 0 2rpx 8rpx rgba(139, 90, 43, 0.15),
    0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.seal-inner::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  right: 6rpx;
  bottom: 6rpx;
  border: 2rpx solid var(--accent-cinnabar);
  border-radius: 4rpx;
  opacity: 0.5;
}

.seal-char {
  font-size: 72rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--accent-cinnabar);
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(199, 62, 58, 0.2);
}

.seal-border {
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 156rpx;
  height: 156rpx;
  border: 3rpx solid var(--accent-cinnabar);
  border-radius: 12rpx;
  opacity: 0.3;
}

.seal-label {
  margin-top: 20rpx;
  font-size: 22rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
  letter-spacing: 4rpx;
}

.hidden-input {
  position: absolute;
  left: 50%;
  top: 20rpx;
  transform: translateX(-50%);
  width: 140rpx;
  height: 140rpx;
  opacity: 0;
}

/* ==================== 开始按钮 ==================== */
.start-btn {
  position: relative;
  display: block;
  width: 100%;
  padding: 28rpx;
  background: var(--card-bg);
  border: 2rpx solid var(--card-border);
  border-radius: 60rpx;
  font-size: 32rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
  text-align: center;
  overflow: hidden;
  margin-bottom: 50rpx;
  transition: all 0.4s ease;
}

.start-btn.active {
  background: linear-gradient(135deg, var(--accent-gold), #C4893A);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 8rpx 30rpx rgba(212, 175, 55, 0.3);
}

.btn-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: shinePass 2s ease-in-out infinite;
}

@keyframes shinePass {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

/* ==================== 轮数选择 ==================== */
.round-section {
  text-align: center;
  margin-bottom: 50rpx;
}

.round-label {
  display: block;
  font-size: 24rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
  margin-bottom: 24rpx;
}

.round-options {
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.round-option {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 20rpx 40rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.round-option.selected {
  background: linear-gradient(135deg, var(--accent-gold), #C4893A);
  border-color: transparent;
}

.option-num {
  font-size: 36rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-primary);
  font-weight: bold;
}

.option-unit {
  font-size: 24rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
}

.round-option.selected .option-num,
.round-option.selected .option-unit {
  color: #fff;
}

/* ==================== 热门关键字 ==================== */
.hot-section {
  margin-bottom: 40rpx;
}

.hot-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.hot-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--card-border), transparent);
}

.hot-title {
  font-size: 24rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
  white-space: nowrap;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 18rpx;
}

.hot-tag {
  padding: 16rpx 30rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 40rpx;
  font-size: 34rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-primary);
  transition: all 0.3s ease;
}

.hot-tag:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, var(--accent-gold), #C4893A);
  color: #fff;
  border-color: transparent;
}

/* ==================== 随机按钮 ==================== */
.random-section {
  margin-top: 40rpx;
}

.divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--card-border), transparent);
}

.divider-text {
  font-size: 24rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
}

.random-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 24rpx;
  background: transparent;
  border: 1rpx dashed var(--card-border);
  border-radius: 60rpx;
  transition: all 0.3s ease;
}

.random-btn:active {
  background: var(--card-bg);
  border-style: solid;
}

.random-icon {
  font-size: 36rpx;
  color: var(--accent-gold);
}

.random-text {
  font-size: 28rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-secondary);
}

/* ==================== 练习界面 ==================== */
.practice-view {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 0 40rpx 60rpx;
}

.practice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 50rpx 0 30rpx;
}

/* 进度印章 */
.progress-seal {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 12rpx 28rpx;
  background: var(--card-bg);
  border: 2rpx solid var(--accent-gold);
  border-radius: 8rpx;
  position: relative;
}

.progress-seal::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  right: 4rpx;
  bottom: 4rpx;
  border: 1rpx solid var(--accent-gold);
  border-radius: 4rpx;
  opacity: 0.3;
}

.seal-num {
  font-size: 32rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--accent-gold);
  font-weight: bold;
}

.seal-div {
  font-size: 24rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
}

.seal-total {
  font-size: 24rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
}

/* ==================== 关键字展示 - 印章风格 ==================== */
.keyword-display {
  display: flex;
  justify-content: center;
  margin: 50rpx 0;
}

.keyword-seal {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.seal-outer {
  padding: 36rpx 70rpx;
  background: linear-gradient(145deg, #FDF6E8 0%, #F5EBD5 100%);
  border: 3rpx solid var(--accent-cinnabar);
  border-radius: 8rpx;
  position: relative;
  box-shadow:
    0 8rpx 30rpx rgba(139, 90, 43, 0.2),
    inset 0 2rpx 10rpx rgba(139, 90, 43, 0.1);
}

.seal-outer::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  border: 1rpx solid var(--accent-cinnabar);
  border-radius: 4rpx;
  opacity: 0.4;
}

.seal-keyword {
  font-size: 80rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--accent-cinnabar);
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(199, 62, 58, 0.15);
}

.seal-decoration {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 70%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--accent-cinnabar), transparent);
  opacity: 0.3;
}

.seal-decoration.top {
  top: -20rpx;
}

.seal-decoration.bottom {
  bottom: -20rpx;
}

/* ==================== 进度点 ==================== */
.progress-section {
  margin-bottom: 50rpx;
}

.progress-dots {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.progress-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--card-bg);
  border: 2rpx solid var(--card-border);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.4s ease;
}

.progress-dot.done {
  background: linear-gradient(135deg, var(--accent-jade), #5A8B6A);
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(93, 138, 107, 0.4);
}

.dot-check {
  font-size: 24rpx;
  color: #fff;
}

/* ==================== 输入区域 ==================== */
.input-section {
  margin-bottom: 30rpx;
}

.input-card {
  background: var(--card-bg);
  border: 2rpx solid var(--card-border);
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
}

.poetry-input {
  width: 100%;
  min-height: 100rpx;
  background: transparent;
  border: none;
  font-size: 30rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-primary);
  line-height: 1.6;
  letter-spacing: 2rpx;
}

.input-placeholder {
  color: var(--text-muted);
  font-size: 30rpx;
}

.input-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
}

/* ==================== 结果展示 ==================== */
.result-section {
  margin-bottom: 30rpx;
  animation: slideUp 0.4s ease-out;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.result-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
}

.result-card.correct {
  background: rgba(93, 138, 107, 0.08);
  border-color: var(--accent-jade);
}

.result-card.wrong {
  background: rgba(199, 62, 58, 0.06);
  border-color: var(--accent-cinnabar);
}

.result-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.result-badge.correct {
  background: var(--accent-jade);
}

.result-badge.wrong {
  background: var(--accent-cinnabar);
}

.result-badge text {
  color: #fff;
}

.result-content {
  flex: 1;
}

.result-title {
  display: block;
  font-size: 30rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-primary);
  font-weight: bold;
  margin-bottom: 8rpx;
}

.result-poetry {
  display: block;
  font-size: 26rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--accent-jade);
  line-height: 1.6;
}

.result-hint {
  display: block;
  font-size: 24rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
  font-style: italic;
  margin-top: 8rpx;
}

.hint-toggle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--accent-gold);
  font-weight: bold;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.hint-toggle:active {
  transform: scale(0.95);
}

.hint-toggle.hide {
  display: none;
}

/* ==================== 操作按钮 ==================== */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.submit-btn {
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(135deg, var(--accent-gold), #C4893A);
  color: #fff;
  font-size: 32rpx;
  font-family: 'STKaiti', '楷体', serif;
  border: none;
  border-radius: 60rpx;
  letter-spacing: 6rpx;
  box-shadow: 0 8rpx 30rpx rgba(212, 175, 55, 0.25);
}

.submit-btn.disabled {
  background: var(--card-bg);
  color: var(--text-muted);
  box-shadow: none;
}

.change-btn {
  width: 100%;
  padding: 24rpx;
  background: transparent;
  border: 1rpx dashed var(--card-border);
  border-radius: 60rpx;
  font-size: 28rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-secondary);
  text-align: center;
}

/* ==================== 随机动效 ==================== */
.random-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.5s ease;
}

.random-overlay.active {
  opacity: 1;
  pointer-events: all;
}

.random-overlay .ink-texture-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 50%, var(--card-bg) 0%, var(--bg-start) 100%);
  opacity: 0.97;
}

.random-overlay .deco-lines {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.random-overlay .deco-line {
  position: absolute;
  background: linear-gradient(90deg, transparent, var(--card-border), transparent);
  height: 1rpx;
  opacity: 0.4;
  animation: lineDrift 6s ease-in-out infinite;
}

.random-overlay .deco-line:nth-child(1) {
  top: 20%;
  width: 60%;
  left: 20%;
  animation-delay: 0s;
}

.random-overlay .deco-line:nth-child(2) {
  top: 75%;
  width: 50%;
  left: 25%;
  animation-delay: 2s;
}

@keyframes lineDrift {
  0%, 100% { opacity: 0.2; transform: translateX(0); }
  50% { opacity: 0.4; transform: translateX(10rpx); }
}

.random-overlay .corner-deco {
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  opacity: 0.15;
}

.random-overlay .corner-deco::before,
.random-overlay .corner-deco::after {
  content: '';
  position: absolute;
  background: var(--accent-gold);
}

.random-overlay .corner-deco.top-left {
  top: 40rpx;
  left: 40rpx;
}
.random-overlay .corner-deco.top-left::before {
  top: 0;
  left: 0;
  width: 50rpx;
  height: 2rpx;
}
.random-overlay .corner-deco.top-left::after {
  top: 0;
  left: 0;
  width: 2rpx;
  height: 50rpx;
}

.random-overlay .corner-deco.top-right {
  top: 40rpx;
  right: 40rpx;
}
.random-overlay .corner-deco.top-right::before {
  top: 0;
  right: 0;
  width: 50rpx;
  height: 2rpx;
}
.random-overlay .corner-deco.top-right::after {
  top: 0;
  right: 0;
  width: 2rpx;
  height: 50rpx;
}

.random-overlay .corner-deco.bottom-left {
  bottom: 40rpx;
  left: 40rpx;
}
.random-overlay .corner-deco.bottom-left::before {
  bottom: 0;
  left: 0;
  width: 50rpx;
  height: 2rpx;
}
.random-overlay .corner-deco.bottom-left::after {
  bottom: 0;
  left: 0;
  width: 2rpx;
  height: 50rpx;
}

.random-overlay .corner-deco.bottom-right {
  bottom: 40rpx;
  right: 40rpx;
}
.random-overlay .corner-deco.bottom-right::before {
  bottom: 0;
  right: 0;
  width: 50rpx;
  height: 2rpx;
}
.random-overlay .corner-deco.bottom-right::after {
  bottom: 0;
  right: 0;
  width: 2rpx;
  height: 50rpx;
}

.random-overlay .char-showcase {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.random-overlay .outer-ring {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  border: 3rpx solid var(--accent-gold);
  opacity: 0.3;
  animation: ringPulse 3s ease-in-out infinite;
}

.random-overlay .outer-ring.dashed {
  border: 2rpx dashed var(--accent-gold);
  opacity: 0.2;
  animation: ringRotate 20s linear infinite;
}

@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.02); opacity: 0.4; }
}

@keyframes ringRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.random-overlay .char-container {
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-bg);
  border-radius: 16rpx;
  border: 3rpx solid var(--accent-gold);
  box-shadow:
    0 0 0 4rpx var(--bg-start),
    0 0 0 6rpx var(--accent-gold),
    0 8rpx 32rpx var(--shadow-color);
}

.random-overlay .main-char {
  font-size: 110rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--accent-cinnabar);
  text-shadow: 0 2rpx 8rpx rgba(199, 62, 58, 0.3);
  transition: all 0.1s ease-out;
}

.random-overlay .main-char.scroll {
  animation: charScroll 0.06s ease-in-out infinite;
}

.random-overlay .main-char.final {
  animation: charStamp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes charScroll {
  0% { transform: scale(1.05) translateY(-2rpx); opacity: 0.85; }
  50% { transform: scale(1.1) translateY(2rpx); opacity: 1; }
  100% { transform: scale(1.05) translateY(-2rpx); opacity: 0.85; }
}

@keyframes charStamp {
  0% { transform: scale(1.8); opacity: 0; }
  40% { transform: scale(0.95) rotate(-3deg); opacity: 1; }
  60% { transform: scale(1.05) rotate(2deg); }
  80% { transform: scale(0.98) rotate(-1deg); }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.random-overlay .hint-text {
  position: absolute;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-muted);
  letter-spacing: 6rpx;
  white-space: nowrap;
}

.random-overlay .hint-dots {
  position: absolute;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
}

.random-overlay .hint-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--accent-gold);
  opacity: 0.4;
  animation: dotPulse 1.2s ease-in-out infinite;
}

.random-overlay .hint-dot:nth-child(2) { animation-delay: 0.2s; }
.random-overlay .hint-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.3); }
}

/* ==================== 成功动效 ==================== */
.success-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.success-popup {
  padding: 60rpx 80rpx;
  background: linear-gradient(135deg, var(--accent-gold), #C4893A);
  border-radius: 24rpx;
  text-align: center;
  animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes popIn {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.success-icon {
  font-size: 72rpx;
  color: #fff;
  animation: spin 1s ease-out;
}

@keyframes spin {
  from { transform: rotate(0deg) scale(0); }
  50% { transform: rotate(180deg) scale(1.2); }
  to { transform: rotate(360deg) scale(1); }
}

.success-text {
  display: block;
  font-size: 36rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: #fff;
  margin-top: 20rpx;
  letter-spacing: 4rpx;
}

/* ==================== 完成弹窗 ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.3s ease;
}

.modal-card {
  position: relative;
  width: 560rpx;
  padding: 70rpx 50rpx 50rpx;
  background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
  border-radius: 24rpx;
  text-align: center;
  border: 1rpx solid var(--card-border);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.modal-seal {
  position: absolute;
  top: -30rpx;
  right: 50rpx;
  width: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  font-size: 36rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--accent-cinnabar);
  background: var(--bg-start);
  border: 2rpx solid var(--accent-cinnabar);
  border-radius: 8rpx;
  transform: rotate(8deg);
}

.modal-title {
  display: block;
  font-size: 40rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--text-primary);
  font-weight: bold;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.modal-text {
  display: block;
  font-size: 30rpx;
  font-family: 'STKaiti', '楷体', serif;
  color: var(--accent-gold);
  margin-bottom: 50rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-family: 'STKaiti', '楷体', serif;
  text-align: center;
  border: none;
}

.modal-btn.primary {
  background: linear-gradient(135deg, var(--accent-gold), #C4893A);
  color: #fff;
}

.modal-btn.secondary {
  background: var(--card-bg);
  color: var(--text-primary);
  border: 1rpx solid var(--card-border);
}


