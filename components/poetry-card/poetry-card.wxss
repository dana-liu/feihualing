.poetry-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
}

.poetry-content {
  text-align: center;
  margin-bottom: 40rpx;
}

.poetry-line {
  display: block;
  color: #f0e6d3;
  font-size: 48rpx;
  line-height: 1.8;
  font-family: 'STKaiti', '楷体', serif;
}

.poetry-info {
  text-align: center;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 40rpx;
}

.poetry-title {
  display: block;
  font-size: 28rpx;
  color: #8b8b8b;
  margin-bottom: 8rpx;
}

.poetry-author {
  font-size: 26rpx;
  color: #6b8cce;
}
